public class Demo {
    public static void main(String[] args) {
        int n = 5;
        for (int i = 1; i <= n; i++) {
            System.out.print("*");
            for (int j = 1; j <= i - 2; j++){
                System.out.print(" ");
            }
            if(i>1)
            {
                System.out.print("*");
            }
            for(int j=1; j<=2*(n-i); j++){
                System.out.print(" ");
            }
            System.out.print("*");
            for (int j = 1; j <= i - 2; j++){
                System.out.print(" ");
            }
            if(i>1)
            {
                System.out.print("*");
            }
            System.out.println(" ");
        }
        for (int i = n; i >= 1; i--) {
            System.out.print("*");
            for (int j = 1; j <= i - 2; j++){
                System.out.print(" ");
            }
            if(i>1)
                System.out.print("*");
            for(int j=1; j<=2*(n-i); j++){
                System.out.print(" ");
            }
            System.out.print("*");
            for (int j = 1; j <= i - 2; j++){
                System.out.print(" ");
            }
            if(i>1)
                System.out.print("*");
            System.out.println(" ");
        }
    }
}




// 5 5 5 5 5
// 5 4 4 4 5
// 5 4 3 4 5
// 5 4 4 4 5
// 5 5 5 5 5
public class Demo {
    public static void main(String[] args) {
        int n = 5;

        for (int i = 1; i <= n; i++) {
            for (int j = 1; j <= n; j++) {

                int min = Math.min(Math.min(i, j), Math.min(n - i + 1, n - j + 1));

                System.out.print(n - min + 1 + " ");
            }
            System.out.println();
        }
    }
}


//     *       *
//   *   *   *   *
// *       *       *

class Demo {
    public static void main(String[] args) {

        int n = 3;
        int cols = 17;

        int[][] pattern = {
            {5, 13},
            {3, 7, 11, 15},
            {1, 9, 17}
        };

        for (int i = 0; i < n; i++) {

            for (int j = 1; j <= cols; j++) {

                boolean print = false;

                for (int k = 0; k < pattern[i].length; k++) {
                    if (pattern[i][k] == j) {
                        print = true;
                        break;
                    }
                }

                if (print) System.out.print("* ");
                else System.out.print("  ");
            }

            System.out.println();
        }
    }
}




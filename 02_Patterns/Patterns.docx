class Demo {
    public static void main(String[] args) {
        int n = 5;
        for(int i=n; i>=1; i--){

            // Spaces
            for(int j=0; j<n-i; j++){
                System.out.print(" ");
            }

            // Stars
            for(int k=0; k<i; k++){
                System.out.print("*");
            }
        System.out.println();
        }
    }
}



//         1
//       1 1
//     1 2 1
//   1 3 3 1
// 1 4 6 4 1
class Demo {
    public static void main(String[] args) {
        int n = 5;

        for(int i=0; i<n; i++){
            for(int j=0; j<n-i-1; j++){
                System.out.print("  ");
            }
            int num = 1;
            for(int j=0; j<=i; j++){
                System.out.print(num + " ");

                num = num * (i - j) / (j + 1);
            }
            System.out.println();
            }
        }


    }



